{
  "name": "kotiq-guard",
  "version": "1.0.0",
  "description": "Scan a repo/project for malicious install hooks **before** you run it. Cloud (Chrome extension + Cloud Run + Gemini) and local (CLI + Ollama/Gemma) — one engine.",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "guard": "ts-node src/agent/graph/guard-graph.ts",
    "serve": "ts-node src/server/server.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && npm run copy:assets",
    "copy:assets": "cp src/agent/agents.yml dist/agent/agents.yml",
    "start": "node dist/server/server.js",
    "users": "ts-node src/users/cli.ts"
  },
  "dependencies": {
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@google-cloud/firestore": "^8.6.0",
    "@google/genai": "^1.0.0",
    "@langchain/core": "^1.1.48",
    "@langchain/google-genai": "^2.1.31",
    "@langchain/google-vertexai": "^2.1.31",
    "@langchain/langgraph": "^1.3.3",
    "@langchain/ollama": "^1.2.7",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "google-auth-library": "^10.6.2",
    "tar-stream": "^3.1.7",
    "yaml": "^2.9.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^25.9.1",
    "@types/tar-stream": "^3.1.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
