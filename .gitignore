# dependencies
node_modules/

# secrets — NEVER commit
.env
.env.*
!.env.example

# build output
dist/
*.tsbuildinfo

# local entitlements store (dev) — holds user emails, not for git
data/entitlements.json

# editors / tooling
.claude
.idea
.vscode

# terraform — state can hold sensitive values; .terraform/ is downloaded plugins.
# NOTE: .terraform.lock.hcl is intentionally NOT ignored — it must be committed.
.terraform/
*.tfstate
*.tfstate.*
crash.log

# extension signing key — pins the extension id; keep private
apps/extension/extension-key.pem

# os
.DS_Store
