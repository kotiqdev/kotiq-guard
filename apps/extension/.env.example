# Copy to .env — the base/local config used by `npm run dev` (points at the local backend).
# For BUILDS use the per-mode files instead: .env.dev (build:dev) and .env.prod (build:prod).
# All VITE_* values are PUBLIC (inlined into the bundle) — not secrets; .env* are git-ignored.
VITE_API_BASE=http://localhost:8080
VITE_OAUTH_CLIENT_ID=your-web-oauth-client-id.apps.googleusercontent.com
