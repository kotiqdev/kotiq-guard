# Copy to .env.prod-local (gitignored). Used by `npm run build:prod-local` (vite --mode prod-local).
# A KEYED build (stable unpacked id) that points at the PROD backend — for verifying prod end-to-end
# LOCALLY before publishing. Load dist/ unpacked in chrome://extensions. These VITE_* values are
# PUBLIC (inlined into the bundle).
#
# NOTE: shares the same id as build:dev (both keyed) — load only ONE keyed build at a time.
# NOTE: add this build's chromiumapp.org redirect to the PROD OAuth client's Authorized redirect URIs
#       so sign-in against the prod backend works.
VITE_API_BASE=https://api.kotiq.dev
VITE_OAUTH_CLIENT_ID=<prod-web-oauth-client-id>.apps.googleusercontent.com
