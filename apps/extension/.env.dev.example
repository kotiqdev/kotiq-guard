# Copy to .env.dev (gitignored). Used by `npm run build:dev` (vite --mode dev).
# These VITE_* values are PUBLIC (inlined into the bundle) — not secrets. They're kept out of the
# public repo only so the dev backend URL isn't advertised.
VITE_API_BASE=https://<dev-cloud-run-url>          # dev Cloud Run service URL
VITE_OAUTH_CLIENT_ID=<dev-web-oauth-client-id>.apps.googleusercontent.com
