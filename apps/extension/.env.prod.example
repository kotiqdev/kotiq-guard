# Copy to .env.prod (gitignored). Used by `npm run build:prod` (vite --mode prod) — the build you
# upload to the Chrome Web Store. These VITE_* values are PUBLIC (they ship in the published bundle).
VITE_API_BASE=https://<prod-cloud-run-url>         # prod Cloud Run service URL
VITE_OAUTH_CLIENT_ID=<prod-web-oauth-client-id>.apps.googleusercontent.com
