# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# Debug logs to stderr: 1 = on, 0 = off
KOTIQ_DEBUG=0

# LLM provider for the explain node: "ollama" (local, default) or "gemini" (Google AI Studio)
LLM_PROVIDER=ollama

# --- Ollama (local) ---
OLLAMA_MODEL=qwen3:32b
OLLAMA_BASE_URL=http://localhost:11434

# --- Gemini (Google AI Studio) — needed only when LLM_PROVIDER=gemini ---
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash
