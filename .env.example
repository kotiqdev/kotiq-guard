# Copy to .env and fill in. .env is git-ignored — never commit real secrets.

# Debug logs to stderr: 1 = on, 0 = off
KOTIQ_DEBUG=0

# LLM provider: "ollama" (local, default) | "gemini" (AI Studio key) | "vertex" (Cloud, ADC)
LLM_PROVIDER=ollama

# --- Ollama (local) ---
OLLAMA_MODEL=qwen3:32b
OLLAMA_BASE_URL=http://localhost:11434

# --- Gemini (Google AI Studio) — needed only when LLM_PROVIDER=gemini ---
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Vertex AI (Google Cloud) — needed only when LLM_PROVIDER=vertex ---
# NO API key. Auth = ADC: run `gcloud auth application-default login` locally;
# on Cloud Run the service account is used automatically.
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=europe-west1
VERTEX_MODEL=gemini-2.5-flash

# --- Cost guard ---
# Max tokens a cloud model (gemini/vertex) may emit per call. Ollama is local/free and exempt.
LLM_MAX_OUTPUT_TOKENS=1024

# --- Auth (allow-listed Google sign-in) ---
# AUTH_ENABLED off locally so curl/dev works; set to "true" on Cloud Run.
AUTH_ENABLED=false
# OAuth 2.0 Client ID created in the GCP console — the expected `aud` of incoming ID tokens.
GOOGLE_OAUTH_CLIENT_ID=
# Who may call /scan: explicit emails and/or verified Workspace domains (comma-separated).
ALLOWED_EMAILS=kotiq.dev@gmail.com
ALLOWED_DOMAINS=kotiq.dev
