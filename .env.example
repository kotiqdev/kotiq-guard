# Copy to .env for LOCAL dev and fill in. .env is git-ignored — never commit real values.
# DEPLOYED config (dev/prod) does NOT live in files here (public repo). It lives as GitHub
# Environment Variables/Secrets and is injected into Cloud Run by .github/workflows/deploy.yml.
# This file documents the full variable surface.

# Debug logs to stderr: 1 = on, 0 = off
KOTIQ_DEBUG=0

# LLM provider: "ollama" (local, default) | "gemini" (AI Studio key) | "vertex" (Cloud, ADC)
LLM_PROVIDER=ollama

# --- Ollama (local) ---
OLLAMA_MODEL=qwen3:32b
OLLAMA_BASE_URL=http://localhost:11434

# --- Gemini (Google AI Studio) — needed only when LLM_PROVIDER=gemini ---
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Vertex AI (Google Cloud) — needed only when LLM_PROVIDER=vertex ---
# NO API key. Auth = ADC: run `gcloud auth application-default login` locally;
# on Cloud Run the service account is used automatically.
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=europe-west1
VERTEX_MODEL=gemini-2.5-flash

# --- Cost guard ---
# Max tokens a cloud model (gemini/vertex) may emit per call. Ollama is local/free and exempt.
LLM_MAX_OUTPUT_TOKENS=1024

# --- Auth (allow-listed Google sign-in) ---
# AUTH_ENABLED off locally so curl/dev works; set to "true" on Cloud Run.
AUTH_ENABLED=false
# OAuth 2.0 Client ID created in the GCP console — the expected `aud` of incoming ID tokens.
GOOGLE_OAUTH_CLIENT_ID=
# Who may call /scan: explicit emails and/or verified Workspace domains (comma-separated).
ALLOWED_EMAILS=you@example.com
ALLOWED_DOMAINS=example.com

# --- User registry (plan / blocked) ---
# 'file' = local JSON (dev only); 'firestore' = Cloud (deployed envs are stateless).
USERS_STORE=file
USERS_FILE=data/users.json
# Firestore collection (each env has its own project → 'users' is enough).
USERS_COLLECTION=users

# --- Repo scanner (optional) ---
# GitHub token lifts the 60/hr unauthenticated rate limit to 5000/hr and reads private repos.
# Read-only; never required.
GITHUB_TOKEN=

# HTTP port (Cloud Run sets PORT automatically).
PORT=8080
